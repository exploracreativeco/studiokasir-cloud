# ============================================================
# StudioKasir Cloud - Environment Variables
# Rename file ini menjadi .env
# ============================================================

# DATABASE - Supabase PostgreSQL
# Ambil dari: Supabase Dashboard → Settings → Database → Connection String
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# AUTH - Generate random string 32 karakter
# Bisa pakai: openssl rand -base64 32
AUTH_SECRET="ganti-dengan-random-string-32-karakter"

# URL Aplikasi
NEXTAUTH_URL="https://app.explorastudio.id"
# Untuk development lokal:
# NEXTAUTH_URL="http://localhost:7733"

# PORT
PORT=7733

# Google OAuth (opsional - untuk login dengan Google)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Feature Flags
NEXT_PUBLIC_FEATURE_SHEETS=true
NEXT_PUBLIC_FEATURE_GENERATE=true
NEXT_PUBLIC_FEATURE_MANAJEMEN=true
NEXT_PUBLIC_FEATURE_CLOUD=true
